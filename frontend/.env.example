# Leave empty/unset for local dev (Vite proxy handles /api -> localhost:5000)
# Set this to your deployed Render backend URL once live, e.g.:
# VITE_API_URL=https://splitease-stay-backend.onrender.com/api
VITE_API_URL=

# Socket.io connection URL (used for live group chat). Optional — if unset,
# it's derived from VITE_API_URL (stripping the trailing /api), or defaults
# to http://localhost:5000 for local dev. Only set this explicitly if your
# Socket.io server lives at a different origin than your REST API.
VITE_SOCKET_URL=

# Web Push: expose the VAPID public key to the frontend so it can call
# PushManager.subscribe(). This is PUBLIC — safe to commit. Keep the private
# key and email only in the backend environment.
# (Not strictly needed — the frontend fetches it from /api/notifications/vapid-public-key —
# but set it here if you want to skip the extra round-trip on first subscribe.)
# VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

